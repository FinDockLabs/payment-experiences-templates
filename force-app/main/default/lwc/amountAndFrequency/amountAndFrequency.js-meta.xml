<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>66.0</apiVersion>
    <description>Amount and Frequency Selector for donation forms</description>
    <isExposed>true</isExposed>
    <masterLabel>Amount and Frequency Selector</masterLabel>
    <targets>
        <target>lightning__FlowScreen</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightning__FlowScreen">
            <property name="frequency" type="String" label="Frequency" description="Donation frequency: 'oneTime' or 'recurring'" role="outputOnly"/>
            <property name="amount" type="Integer" label="Selected Amount" description="The selected or entered donation amount" role="outputOnly"/>
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>
