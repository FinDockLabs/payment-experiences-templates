        </targetConfig>
        <targetConfig targets="lightningCommunity__Default">
            <property name="currentPage" type="Integer" label="Current Progress"/>
            <property name="totalPages" type="Integer" label="Total Progress"/>
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>